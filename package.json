{
  "name": "@gaws-hub/sdk",
  "version": "0.1.0",
  "description": "SDK for building and calling gaws-hub agents: the service contract (sync + job services), hub-brokered bus/store, and a Hono agent server with a built-in job host.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  },
  "engines": { "node": ">=20" },
  "license": "MIT"
}
